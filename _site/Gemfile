source "https://rubygems.org"

# Jekyll 3.9 / Liquid 4 still calls tainted?/untaint, removed in modern Ruby.
# Defining the shim here ensures it is loaded before Bundler boots Jekyll.
class Object
  unless method_defined?(:tainted?)
    def tainted?
      false
    end
  end

  unless method_defined?(:untaint)
    def untaint
      self
    end
  end
end

gem "github-pages", group: :jekyll_plugins
gem "webrick", "~> 1.8" # for local `jekyll serve` on Ruby 3
gem "csv" # Ruby 3.4+/4 no longer ships csv as a default gem for Jekyll 3.9
gem "bigdecimal" # Liquid/Jekyll on Ruby 3.4+/4 needs this explicitly
